    "onboarding.permission.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To read the active window title, WorkTrace needs Accessibility permission. You can grant it now, or later in Settings. Time tracking works either way."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "使用中のウィンドウタイトルを取得するには、アクセシビリティ権限が必要です。今すぐ、または後で設定から許可できます。許可しなくても時間計測は動作します。"
          }
        }
      }
    },
    "onboarding.permission.grant": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grant Accessibility Permission"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限を許可"
          }
        }
      }
    },
    "onboarding.permission.granted": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Permission granted"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "許可されました"
          }
        }
      }
    },
    "onboarding.permission.optional": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This step is optional."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この手順は任意です。"
          }
        }
      }
    },
    "onboarding.permission.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accessibility permission"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセシビリティ権限"
          }
        }
      }
    },
    "onboarding.privacy.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add privacy zones in Settings to exclude or mask sensitive apps and sites. Window titles are hashed before they are ever written to disk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定でプライバシーゾーンを追加し、機密アプリやサイトを除外・マスクできます。ウィンドウタイトルは保存前にハッシュ化されます。"
          }
        }
      }
    },
    "onboarding.privacy.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Privacy protections"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プライバシー保護"
          }
        }
      }
    },
    "onboarding.skip": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スキップ"
          }
        }
      }
    },
    "onboarding.storage.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything is stored in a private database on this Mac. Nothing is sent anywhere unless you explicitly enable it in a future version."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてこの Mac 内のプライベートなデータベースに保存されます。明示的に有効化しない限り、外部へ送信されることはありません。"
          }
        }
      }
    },
    "onboarding.storage.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data stays local"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データはローカルに保存"
          }
        }
      }
    },
    "onboarding.tracking.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only lightweight metadata: the active app, window title, and whether you are idle. Never screenshots, keystrokes, or full browsing history."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録するのは軽量なメタデータのみ（使用中のアプリ、ウィンドウタイトル、離席状態）。スクリーンショットやキー入力、全閲覧履歴は取得しません。"
          }
        }
      }
    },
    "onboarding.tracking.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What is tracked"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録される内容"
          }
        }
      }
    },
    "onboarding.welcome.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WorkTrace helps you record how you spend your work time and turn it into daily reports and billing evidence — all on your own Mac."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "WorkTrace は作業時間の記録を助け、日報や請求の根拠に変換します。すべてこの Mac 内で完結します。"
          }
        }
      }
    },
    "onboarding.welcome.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to WorkTrace"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "WorkTrace へようこそ"
          }
        }
      }
    },
